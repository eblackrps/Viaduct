# Local bootstrap credentials for repo-run workflows. Leave empty to rely on
# tenant or service-account keys instead of basic auth.
VIADUCT_USERNAME=
VIADUCT_PASSWORD=

# Admin API key for /api/v1/admin/* routes. Leave empty to disable admin-key
# auth. Use a long random value with no default secret committed here.
VIADUCT_ADMIN_KEY=

# Comma-separated list of allowed cross-origin dashboard origins. Default:
# same-origin only when empty. Do not use "*" when API-key auth is enabled.
VIADUCT_ALLOWED_ORIGINS=

# Allow anonymous requests against the default tenant to inherit admin rights.
# Default: false. Valid values: true or false.
VIADUCT_ALLOW_ANONYMOUS_ADMIN=false

# Background workspace job timeout. Default: 2m. Valid range: any positive Go
# duration such as 30s, 2m, or 5m.
VIADUCT_WORKSPACE_JOB_TIMEOUT=2m

# Explicit dashboard asset directory for `viaduct serve-api`. Default: auto-
# detect built web assets from standard repo or package locations.
VIADUCT_WEB_DIR=

# Runtime dashboard auth-session TTL for non-persistent browser sessions.
# Default: 12h. Valid range: any positive Go duration.
VIADUCT_AUTH_SESSION_TTL=12h

# Runtime dashboard auth-session TTL for "remember me" sessions. Default: 720h
# (30 days). Valid range: any positive Go duration.
VIADUCT_AUTH_REMEMBER_TTL=720h

# API response Content Security Policy. Default: `default-src 'none';
# frame-ancestors 'none'; base-uri 'none'; form-action 'none'`.
VIADUCT_API_CSP=

# Dashboard Content Security Policy. Default: same-origin policy with inline
# styles allowed for the built dashboard shell.
VIADUCT_DASHBOARD_CSP=

# PostgreSQL read-query timeout. Default: 5s. Valid range: any positive Go
# duration.
VIADUCT_DB_READ_TIMEOUT=5s

# PostgreSQL write-query timeout. Default: 10s. Valid range: any positive Go
# duration.
VIADUCT_DB_WRITE_TIMEOUT=10s

# PostgreSQL max open connections. Default: 25. Valid range: positive integer.
VIADUCT_DB_MAX_OPEN_CONNS=25

# PostgreSQL max idle connections. Default: 5. Valid range: positive integer.
VIADUCT_DB_MAX_IDLE_CONNS=5

# PostgreSQL connection max lifetime. Default: 5m. Valid range: any positive Go
# duration.
VIADUCT_DB_CONN_MAX_LIFETIME=5m

# Dashboard bootstrap service-account key for local development. Prefer this
# over a tenant key for normal operator flows.
VITE_VIADUCT_SERVICE_ACCOUNT_KEY=

# Dashboard bootstrap tenant API key for break-glass admin or local bootstrap
# scenarios.
VITE_VIADUCT_API_KEY=

# Frontend request timeout in milliseconds. Default: 30000. Valid range:
# positive integer.
VITE_VIADUCT_API_TIMEOUT_MS=30000
