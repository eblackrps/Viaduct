# Prefer a named service account key for normal dashboard use.
VITE_VIADUCT_SERVICE_ACCOUNT_KEY=

# Keep the tenant key for advanced or break-glass admin access.
VITE_VIADUCT_API_KEY=

# Frontend request timeout in milliseconds. Default: 30000. Valid range:
# positive integer.
VITE_VIADUCT_API_TIMEOUT_MS=30000

# Leave both keys empty to use the Get started screen.
